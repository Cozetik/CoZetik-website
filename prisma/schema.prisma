generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      Role     @default(SUPER_ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String?
  imageUrl    String?
  visible     Boolean     @default(true)
  order       Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  formations  Formation[]

  @@index([visible, order])
}

model Formation {
  id            String                 @id @default(cuid())
  title         String
  slug          String                 @unique
  description   String
  program       String
  duration      String?
  imageUrl      String?
  visible       Boolean                @default(true)
  order         Int                    @default(0)
  categoryId    String
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  isCertified   Boolean                @default(false)
  isFlexible    Boolean                @default(true)
  level         String?
  maxStudents   Int?
  objectives    String[]
  prerequisites String?
  rating        Float?                 @default(0)
  reviewsCount  Int                    @default(0)
  studentsCount Int                    @default(0)
  category      Category               @relation(fields: [categoryId], references: [id])
  faqs          FormationFAQ[]
  packs         FormationPack[]
  sessions      FormationSession[]
  steps         FormationStep[]
  inscriptions  FormationInscription[]

  @@index([visible, order])
  @@index([categoryId, visible])
}

model FormationSession {
  id          String    @id @default(cuid())
  formationId String
  startDate   DateTime
  endDate     DateTime
  location    String?
  maxSeats    Int?
  available   Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  formation   Formation @relation(fields: [formationId], references: [id], onDelete: Cascade)
}

model Partner {
  id          String   @id @default(cuid())
  name        String
  description String?
  logoUrl     String?
  websiteUrl  String?
  visible     Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([visible, order])
}

model BlogPost {
  id               String    @id @default(cuid())
  title            String
  slug             String    @unique
  content          String
  excerpt          String?
  imageUrl         String?
  visible          Boolean   @default(false)
  publishedAt      DateTime?
  seoTitle         String?
  seoDescription   String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  themeId          String?
  aiMetadata       Json?
  aiScore          Float?
  featuredProg     String?
  isReviewRequired Boolean   @default(true)
  theme            Theme?    @relation(fields: [themeId], references: [id])

  @@index([visible, publishedAt])
  @@index([themeId, visible])
}

model Theme {
  id    String     @id @default(cuid())
  name  String     @unique
  slug  String     @unique
  posts BlogPost[]
}

model ContactRequest {
  id        String        @id @default(cuid())
  name      String
  email     String
  message   String
  status    RequestStatus @default(NEW)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@map("contact_requests")
}

model FormationInscription {
  id          String        @id @default(cuid())
  name        String
  email       String
  phone       String
  message     String
  formationId String
  status      RequestStatus @default(NEW)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  formation   Formation     @relation(fields: [formationId], references: [id])

  @@map("formation_inscriptions")
}

model FormationStep {
  id          String    @id @default(cuid())
  formationId String
  order       Int
  title       String
  description String
  duration    String?
  keyPoints   String[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  formation   Formation @relation(fields: [formationId], references: [id], onDelete: Cascade)

  @@unique([formationId, order])
  @@index([formationId])
}

model FormationFAQ {
  id          String    @id @default(cuid())
  formationId String
  order       Int
  question    String
  answer      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  formation   Formation @relation(fields: [formationId], references: [id], onDelete: Cascade)

  @@unique([formationId, order])
  @@index([formationId])
}

model FormationPack {
  id            String    @id @default(cuid())
  formationId   String
  name          String
  description   String?
  price         Float
  originalPrice Float?
  savings       String?
  features      String[]
  isPopular     Boolean   @default(false)
  order         Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  formation     Formation @relation(fields: [formationId], references: [id], onDelete: Cascade)

  @@unique([formationId, order])
  @@index([formationId])
}

model QuizQuestion {
  id        String       @id @default(cuid())
  order     Int          @unique
  question  String
  visible   Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  options   QuizOption[]

  @@index([order, visible])
}

model QuizOption {
  id         String       @id @default(cuid())
  questionId String
  letter     String
  text       String
  order      Int
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  question   QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, letter])
  @@index([questionId])
}

model QuizProfile {
  id                     String   @id @default(cuid())
  letter                 String   @unique
  name                   String
  emoji                  String
  color                  String
  blocageRacine          String
  desir                  String
  phraseMiroir           String
  programmeSignature     String
  modulesComplementaires String[]
  visible                Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([letter])
}

model QuizResponse {
  id             String   @id @default(cuid())
  email          String?
  answers        Json
  profileLetter  String
  recommendation Json
  createdAt      DateTime @default(now())

  @@index([createdAt])
  @@index([profileLetter])
}

model Candidature {
  id                String        @id @default(cuid())
  civility          String
  firstName         String
  lastName          String
  email             String
  phone             String
  address           String?
  postalCode        String?
  city              String?
  formation         String
  educationLevel    String
  currentSituation  String
  startDate         String?
  motivation        String
  cvUrl             String?
  coverLetterUrl    String?
  otherDocumentUrl  String?
  acceptPrivacy     Boolean       @default(false)
  acceptNewsletter  Boolean       @default(false)
  status            RequestStatus @default(NEW)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  categoryFormation String
  birthDate         DateTime
  pack                 String?
  cpfAmount            Float?
  additionalFormations String[]      @default([])

  @@map("candidatures")
}

model Value {
  id          String   @id @default(cuid())
  order       Int      @unique @default(0)
  title       String
  description String
  visible     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([visible, order])
}

enum Role {
  SUPER_ADMIN
}

enum RequestStatus {
  NEW
  TREATED
  ARCHIVED
}
